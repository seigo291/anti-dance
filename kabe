local player = game.Players.LocalPlayer
local runService = game:GetService("RunService")

local spawnLocation = nil
local isTeleporting = false

-- UI
local screenGui = Instance.new("ScreenGui")
screenGui.Parent = player:WaitForChild("PlayerGui")
screenGui.ResetOnSpawn = false

local function createBtn(text, pos, color)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 45, 0, 45)
    btn.Position = pos
    btn.BackgroundColor3 = color
    btn.Text = text
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Font = Enum.Font.SourceSansBold
    btn.Parent = screenGui
    Instance.new("UICorner").Parent = btn
    return btn
end

local setBtn = createBtn("SET", UDim2.new(1, -115, 0, 25), Color3.fromRGB(0, 100, 200))
local getBtn = createBtn("GET", UDim2.new(1, -60, 0, 25), Color3.fromRGB(60, 60, 60))

-- [SET] 処理
setBtn.MouseButton1Click:Connect(function()
    local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if hrp then
        spawnLocation = hrp.CFrame
        setBtn.BackgroundColor3 = Color3.fromRGB(0, 255, 100)
        getBtn.BackgroundColor3 = Color3.fromRGB(255, 165, 0)
        task.wait(0.5)
        setBtn.BackgroundColor3 = Color3.fromRGB(0, 100, 200)
    end
end)

-- [GET] 処理：サーバーの監視をバグらせて納品を確定させる
getBtn.MouseButton1Click:Connect(function()
    if isTeleporting or not spawnLocation then return end
    isTeleporting = true
    getBtn.BackgroundColor3 = Color3.fromRGB(255, 0, 0)

    local char = player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    
    if hrp and spawnLocation then
        local enemyPos = hrp.CFrame
        
        -- 1. 盗んでいるキャラを特定
        local target = nil
        for _, v in pairs(workspace:GetDescendants()) do
            if v:IsA("BasePart") and not v:IsDescendantOf(char) then
                if (v.Position - hrp.Position).Magnitude < 10 then
                    target = v:FindFirstAncestorOfClass("Model")
                    if target then break end
                end
            end
        end

        if target and target:FindFirstChild("HumanoidRootPart") then
            local tHRP = target.HumanoidRootPart
            
            -- 2. 自陣の判定エリアへ移動
            hrp.CFrame = spawnLocation
            tHRP.CFrame = spawnLocation
            
            -- 3. 【新ロジック】サーバーの「巻き戻し」を防ぐための強制アンカー＆ラグ
            -- 0.5秒間、物理演算を完全に停止させて「ここにいる」という状態を固定する
            tHRP.Anchored = true
            hrp.Anchored = true
            
            -- 4. 0.5秒かけて「納品エリア」の中でターゲットを直接回転させる
            -- これによりサーバーにTouchedイベントを多重送信する
            local startTime = tick()
            while tick() - startTime < 0.6 do
                tHRP.CFrame = spawnLocation * CFrame.Angles(0, math.rad(tick()*360), 0)
                runService.Heartbeat:Wait()
            end
            
            -- 5. アンカー解除して敵基地へ帰還
            tHRP.Anchored = false
            hrp.Anchored = false
            hrp.CFrame = enemyPos
        end
    end

    getBtn.BackgroundColor3 = Color3.fromRGB(255, 165, 0)
    isTeleporting = false
end)
