local ReplicatedStorage = game:GetService("ReplicatedStorage")
local AdminEvent = Instance.new("RemoteEvent", ReplicatedStorage)
AdminEvent.Name = "AdminEvent"

AdminEvent.OnServerEvent:Connect(function(player, action, targetName)
    -- アクションごとの処理
    if action == "Kick" then
        local target = game.Players:FindFirstChild(targetName)
        if target then target:Kick("\n【管理通知】\nキックされました。") end
        
    elseif action == "BlindAll" then
        for _, p in pairs(game.Players:GetPlayers()) do
            local cc = Instance.new("ColorCorrectionEffect", game.Lighting)
            cc.Name = "AdminBlind"
            cc.Brightness = 10
        end
        
    elseif action == "CancelAll" then
        for _, effect in pairs(game.Lighting:GetChildren()) do
            if effect.Name == "AdminBlind" then effect:Destroy() end
        end
        
    elseif action == "GiveGlove" then
        local glove = game.ServerStorage:FindFirstChild("SuperGlove")
        if glove then glove:Clone().Parent = player.Backpack end
    end
end)
