local player = game.Players.LocalPlayer
local tweenService = game:GetService("TweenService")

local spawnLocation = nil
local isTeleporting = false

-- UI
local screenGui = Instance.new("ScreenGui")
screenGui.Parent = player:WaitForChild("PlayerGui")
screenGui.ResetOnSpawn = false

local function createBtn(text, pos, color)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 45, 0, 45)
    btn.Position = pos
    btn.BackgroundColor3 = color
    btn.Text = text
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Font = Enum.Font.SourceSansBold
    btn.Parent = screenGui
    Instance.new("UICorner").Parent = btn
    return btn
end

local setBtn = createBtn("SET", UDim2.new(1, -115, 0, 25), Color3.fromRGB(0, 100, 200))
local getBtn = createBtn("GET", UDim2.new(1, -60, 0, 25), Color3.fromRGB(60, 60, 60))

-- キャラクターの状態管理
local function toggleSafety(state)
    local char = player.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    if hum then
        hum:SetStateEnabled(Enum.HumanoidStateType.Dead, not state)
        -- 貫通属性を付与
        for _, v in pairs(char:GetDescendants()) do
            if v:IsA("BasePart") then v.CanCollide = not state end
        end
    end
end

-- [SET] 処理
setBtn.MouseButton1Click:Connect(function()
    local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if hrp then
        spawnLocation = hrp.CFrame
        setBtn.BackgroundColor3 = Color3.fromRGB(0, 255, 100)
        getBtn.BackgroundColor3 = Color3.fromRGB(255, 165, 0)
        task.wait(0.5)
        setBtn.BackgroundColor3 = Color3.fromRGB(0, 100, 200)
    end
end)

-- [GET] 処理：納品ポイントの3メートル手前に飛び、そこから歩く
getBtn.MouseButton1Click:Connect(function()
    if isTeleporting or not spawnLocation then return end
    isTeleporting = true
    getBtn.BackgroundColor3 = Color3.fromRGB(255, 0, 0)

    local char = player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    local hum = char and char:FindFirstChild("Humanoid")
    
    if hrp and hum then
        local enemyPos = hrp.CFrame -- 敵基地の場所
        
        -- 1. 納品ポイントの「少し手前」を計算
        local offset = spawnLocation * CFrame.new(0, 0, 3) -- 3スタッド手前
        
        -- 2. 安全確保して移動
        toggleSafety(true)
        hrp.CFrame = offset
        task.wait(0.1)
        
        -- 3. 【新機能】自動歩行で納品ポイントへ突っ込む
        hum:MoveTo(spawnLocation.Position)
        
        -- 4. 納品完了を待つ（MoveToが終わるまで、最大1秒）
        hum.MoveToFinished:Wait()
        task.wait(0.2) -- 念のための余裕
        
        -- 5. 敵基地へ戻る（戻る時はスムーズに）
        hrp.CFrame = enemyPos
        toggleSafety(false)
    end

    getBtn.BackgroundColor3 = Color3.fromRGB(255, 165, 0)
    isTeleporting = false
end)
