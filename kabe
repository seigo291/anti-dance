local player = game.Players.LocalPlayer
local runService = game:GetService("RunService")
local noclipEnabled = false

-- UI
local screenGui = Instance.new("ScreenGui")
screenGui.Parent = player:WaitForChild("PlayerGui")
screenGui.ResetOnSpawn = false
local toggleBtn = Instance.new("TextButton")
toggleBtn.Size = UDim2.new(0, 45, 0, 45)
toggleBtn.Position = UDim2.new(1, -65, 0, 25)
toggleBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
toggleBtn.Text = "OFF"
toggleBtn.Parent = screenGui
Instance.new("UICorner").Parent = toggleBtn

toggleBtn.MouseButton1Click:Connect(function()
    noclipEnabled = not noclipEnabled
    toggleBtn.Text = noclipEnabled and "ON" or "OFF"
    toggleBtn.BackgroundColor3 = noclipEnabled and Color3.fromRGB(0, 200, 100) or Color3.fromRGB(40, 40, 40)
end)

-- 戻される動き（サーバーサイド・テレポート）への対抗ロジック
runService.Stepped:Connect(function()
    if not noclipEnabled then return end
    
    local char = player.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    -- 1. 自身の判定を完全に無効化
    for _, part in pairs(char:GetDescendants()) do
        if part:IsA("BasePart") then
            part.CanCollide = false
        end
    end

    -- 2. 【最重要】周辺の「透明な壁」を物理的にではなく、自分の世界から「隠蔽」する
    -- これにより、クライアント側での衝突計算そのものを発生させない
    local nearby = workspace:GetPartBoundsInRadius(hrp.Position, 15)
    for _, p in pairs(nearby) do
        -- 透明な壁（窓）や鉄格子などの怪しいパーツを狙い撃ち
        if p:IsA("BasePart") and (p.Transparency > 0 or p.Name:lower():find("window") or p.Name:lower():find("bar")) then
            -- 削除(Destroy)すると再生成される可能性があるため、Parentを一時的にnilにする（高度な隠蔽）
            p.CanCollide = false
            -- p.Parent = nil -- 戻されるのが酷い場合はここを有効化（自己責任）
        end
        
        -- 盗んでいる対象のキャラも一緒に判定を切る
        if p.Parent:FindFirstChild("Humanoid") and p.Parent ~= char then
            for _, limb in pairs(p.Parent:GetChildren()) do
                if limb:IsA("BasePart") then limb.CanCollide = false end
            end
        end
    end

    -- 3. ネットワークラグを利用した「位置固定」
    -- サーバーからの座標上書きに抵抗するため、微弱な反発力を維持
    hrp.Velocity = hrp.CFrame.LookVector * 20 -- 前方への推進力を強制維持
end)
