local player = game.Players.LocalPlayer
local runService = game:GetService("RunService")

local noclipEnabled = false
local godModeEnabled = false

-- UI
local screenGui = Instance.new("ScreenGui")
screenGui.Parent = player:WaitForChild("PlayerGui")
screenGui.ResetOnSpawn = false

local function createBtn(text, pos, color)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 70, 0, 45)
    btn.Position = pos
    btn.BackgroundColor3 = color
    btn.Text = text
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Font = Enum.Font.SourceSansBold
    btn.Parent = screenGui
    Instance.new("UICorner").Parent = btn
    return btn
end

-- ボタン配置（右上に並べます）
local noclipBtn = createBtn("Noclip", UDim2.new(1, -160, 0, 25), Color3.fromRGB(60, 60, 60))
local godBtn = createBtn("GodMode", UDim2.new(1, -80, 0, 25), Color3.fromRGB(60, 60, 60))

-- 1. 壁抜け (Noclip) ロジック
noclipBtn.MouseButton1Click:Connect(function()
    noclipEnabled = not noclipEnabled
    noclipBtn.BackgroundColor3 = noclipEnabled and Color3.fromRGB(0, 200, 100) or Color3.fromRGB(60, 60, 60)
end)

runService.Stepped:Connect(function()
    if noclipEnabled and player.Character then
        for _, v in pairs(player.Character:GetDescendants()) do
            if v:IsA("BasePart") then
                v.CanCollide = false
            end
        end
    end
end)

-- 2. 無敵 & ノックバック無効 (God Mode) ロジック
godBtn.MouseButton1Click:Connect(function()
    godModeEnabled = not godModeEnabled
    godBtn.BackgroundColor3 = godModeEnabled and Color3.fromRGB(255, 0, 100) or Color3.fromRGB(60, 60, 60)
    
    local char = player.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    
    if godModeEnabled and hum then
        -- ダメージを受けないようにステートを変更
        hum:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
        hum:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false)
        hum:SetStateEnabled(Enum.HumanoidStateType.GettingUp, false)
    else
        hum:SetStateEnabled(Enum.HumanoidStateType.FallingDown, true)
        hum:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, true)
        hum:SetStateEnabled(Enum.HumanoidStateType.GettingUp, true)
    end
end)

-- ノックバック（物理的な衝撃）を常に打ち消す
runService.Heartbeat:Connect(function()
    if godModeEnabled and player.Character then
        local hrp = player.Character:FindFirstChild("HumanoidRootPart")
        if hrp then
            hrp.Velocity = Vector3.new(0, hrp.Velocity.Y, 0) -- 横方向の衝撃をリセット
            hrp.RotVelocity = Vector3.new(0, 0, 0) -- 回転衝撃をリセット
        end
    end
end)
