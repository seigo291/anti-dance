local player = game.Players.LocalPlayer
local runService = game:GetService("RunService")
local noclipEnabled = false

-- UI
local screenGui = Instance.new("ScreenGui")
screenGui.Parent = player:WaitForChild("PlayerGui")
screenGui.ResetOnSpawn = false
local toggleBtn = Instance.new("TextButton")
toggleBtn.Size = UDim2.new(0, 50, 0, 50)
toggleBtn.Position = UDim2.new(1, -70, 0, 30)
toggleBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
toggleBtn.Text = "PUSH"
toggleBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
toggleBtn.Parent = screenGui
Instance.new("UICorner").Parent = toggleBtn

-- 透明な足場を作成（サーバーからは見えない）
local platform = Instance.new("Part")
platform.Size = Vector3.new(10, 1, 10)
platform.Transparency = 1 -- 完全に透明
platform.Anchored = true
platform.CanCollide = false -- 初期はオフ
platform.Parent = workspace

toggleBtn.MouseButton1Click:Connect(function()
    if noclipEnabled then return end
    noclipEnabled = true
    toggleBtn.BackgroundColor3 = Color3.fromRGB(0, 255, 255)
    
    local char = player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then noclipEnabled = false return end

    -- 1. 自身の判定をオフ
    for _, v in pairs(char:GetDescendants()) do
        if v:IsA("BasePart") then v.CanCollide = false end
    end

    -- 2. 足元に自分専用の床を設置（基地の床に触れさせない）
    platform.Position = hrp.Position - Vector3.new(0, 3.5, 0)
    platform.CanCollide = true

    -- 3. 周辺の壁を消去
    local nearby = workspace:GetPartBoundsInRadius(hrp.Position, 15)
    local hidden = {}
    for _, p in pairs(nearby) do
        if p:IsA("BasePart") and p.Transparency > 0 and p ~= platform then
            local op = p.Parent
            table.insert(hidden, {part = p, parent = op})
            p.Parent = nil
        end
    end

    -- 0.2秒間の「無敵時間」
    task.wait(0.2)

    -- 復元
    platform.CanCollide = false
    for _, data in pairs(hidden) do
        data.part.Parent = data.parent
    end

    noclipEnabled = false
    toggleBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
end)
