local player = game.Players.LocalPlayer
local runService = game:GetService("RunService")

local spawnLocation = nil
local isTeleporting = false

-- UI
local screenGui = Instance.new("ScreenGui")
screenGui.Parent = player:WaitForChild("PlayerGui")
screenGui.ResetOnSpawn = false

local function createBtn(text, pos, color)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 45, 0, 45)
    btn.Position = pos
    btn.BackgroundColor3 = color
    btn.Text = text
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Font = Enum.Font.SourceSansBold
    btn.Parent = screenGui
    Instance.new("UICorner").Parent = btn
    return btn
end

local setBtn = createBtn("SET", UDim2.new(1, -115, 0, 25), Color3.fromRGB(0, 100, 200))
local getBtn = createBtn("GET", UDim2.new(1, -60, 0, 25), Color3.fromRGB(60, 60, 60))

-- [SET] 処理
setBtn.MouseButton1Click:Connect(function()
    local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if hrp then
        spawnLocation = hrp.CFrame
        setBtn.BackgroundColor3 = Color3.fromRGB(0, 255, 100)
        getBtn.BackgroundColor3 = Color3.fromRGB(255, 165, 0)
        task.wait(0.5)
        setBtn.BackgroundColor3 = Color3.fromRGB(0, 100, 200)
    end
end)

-- [GET] 処理：物理エンジンの隙間を突く「瞬間強制納品」
getBtn.MouseButton1Click:Connect(function()
    if isTeleporting or not spawnLocation then return end
    isTeleporting = true
    getBtn.BackgroundColor3 = Color3.fromRGB(255, 0, 0)

    local char = player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    
    if hrp then
        local enemyPos = hrp.CFrame
        
        -- 1. ターゲット（盗んでいるキャラ）を特定し、物理属性をハック
        local target = nil
        for _, v in pairs(workspace:GetDescendants()) do
            if v:IsA("BasePart") and not v:IsDescendantOf(char) then
                if (v.Position - hrp.Position).Magnitude < 10 then
                    target = v:FindFirstAncestorOfClass("Model")
                    if target then break end
                end
            end
        end

        if target and target:FindFirstChild("HumanoidRootPart") then
            local targetHRP = target.HumanoidRootPart
            
            -- 2. 【最重要】ネットワーク的な「所有権」の隙を作るため、
            -- 一瞬だけターゲットを自分の一部のように振る舞わせる
            local function moveSequence(cf)
                hrp.CFrame = cf
                targetHRP.CFrame = cf
                -- サーバーに「これは自然な移動だ」と思わせるために微細な速度を与える
                targetHRP.Velocity = Vector3.new(0, -2, 0) 
            end

            -- 3. 自陣へワープ（滞在時間を少し伸ばす: 0.8秒）
            -- サーバーが「敵基地から消えた」ことを認識するまでの猶予
            moveSequence(spawnLocation)
            
            -- 4. 判定を強制するために、納品ポイントを「踏みしめる」動き
            local startTime = tick()
            while tick() - startTime < 0.8 do
                targetHRP.CFrame = spawnLocation * CFrame.new(0, math.sin(tick()*10)*0.1, 0)
                runService.Heartbeat:Wait()
            end
            
            -- 5. 敵基地へ戻る
            hrp.CFrame = enemyPos
        else
            -- ターゲットが見つからない場合、自分だけワープして戻る（デバッグ用）
            hrp.CFrame = spawnLocation
            task.wait(0.5)
            hrp.CFrame = enemyPos
        end
    end

    getBtn.BackgroundColor3 = Color3.fromRGB(255, 165, 0)
    isTeleporting = false
end)
