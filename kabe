-- [重要] 死亡判定を一時的にロックする関数
local function setDeadState(enabled)
    local hum = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
    if hum then
        hum:SetStateEnabled(Enum.HumanoidStateType.Dead, enabled)
    end
end

-- 高精度・強制判定テレポート
local function forceDepositTeleport(targetCFrame)
    local char = player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    -- 1. 衝突判定をオフにし、死亡を一時禁止
    setDeadState(false)
    for _, v in pairs(char:GetDescendants()) do
        if v:IsA("BasePart") then v.CanCollide = false end
    end

    -- 2. Tweenで超高速移動 (0.1秒)
    local tween = tweenService:Create(hrp, TweenInfo.new(0.1, Enum.EasingStyle.Linear), {CFrame = targetCFrame})
    tween:Play()
    tween.Completed:Wait()

    -- 3. 【新機能】強制判定発生 (微細な揺さぶり)
    -- サーバーに「パーツに触れた」というTouchedイベントを強制的に送るための処理
    for i = 1, 3 do
        hrp.CFrame = hrp.CFrame + Vector3.new(0, 0.1, 0)
        task.wait(0.02)
        hrp.CFrame = hrp.CFrame - Vector3.new(0, 0.1, 0)
        task.wait(0.02)
    end

    -- 4. 少し待ってから死亡判定を戻す
    task.wait(0.1)
    setDeadState(true)
end

-- [SET] 処理
setBtn.MouseButton1Click:Connect(function()
    local char = player.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        spawnLocation = char.HumanoidRootPart.CFrame
        setBtn.BackgroundColor3 = Color3.fromRGB(0, 255, 100)
        getBtn.BackgroundColor3 = Color3.fromRGB(255, 165, 0)
        task.wait(0.5)
        setBtn.BackgroundColor3 = Color3.fromRGB(0, 100, 200)
    end
end)

-- [GET] 処理
getBtn.MouseButton1Click:Connect(function()
    if isTeleporting or not spawnLocation then return end
    isTeleporting = true
    getBtn.BackgroundColor3 = Color3.fromRGB(255, 0, 0)

    local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if hrp then
        local currentPos = hrp.CFrame
        
        -- 納品場所へ
        forceDepositTeleport(spawnLocation)
        task.wait(0.3) -- 判定が受理されるまで少し長めに待機
        
        -- 敵基地へ戻る
        forceDepositTeleport(currentPos)
    end

    getBtn.BackgroundColor3 = Color3.fromRGB(255, 165, 0)
    isTeleporting = false
end)
