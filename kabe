local player = game.Players.LocalPlayer
local runService = game:GetService("RunService")
local noclipEnabled = false

-- UI部分は変更なし
local screenGui = Instance.new("ScreenGui")
screenGui.Parent = player:WaitForChild("PlayerGui")
screenGui.ResetOnSpawn = false
local toggleBtn = Instance.new("TextButton")
toggleBtn.Size = UDim2.new(0, 45, 0, 45)
toggleBtn.Position = UDim2.new(1, -65, 0, 25)
toggleBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
toggleBtn.Text = "OFF"
toggleBtn.Parent = screenGui
local corner = Instance.new("UICorner")
corner.Parent = toggleBtn

toggleBtn.MouseButton1Click:Connect(function()
    noclipEnabled = not noclipEnabled
    toggleBtn.Text = noclipEnabled and "ON" or "OFF"
    toggleBtn.BackgroundColor3 = noclipEnabled and Color3.fromRGB(0, 200, 100) or Color3.fromRGB(40, 40, 40)
end)

-- 戻される動きを阻止する強化ロジック
runService.Stepped:Connect(function()
    local char = player.Character
    if not char then return end

    if noclipEnabled then
        -- 1. 自身のパーツ判定を「毎フレーム」強制的にオフ
        -- (オフにした直後にゲーム側にオンにされるのを防ぐ)
        for _, part in pairs(char:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = false
            end
        end

        -- 2. 速度を固定して物理演算の「弾き出し」を無効化
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hrp then
            -- わずかに上方向に力をかけることで、床や壁への埋まり判定を回避
            hrp.Velocity = Vector3.new(hrp.Velocity.X, 0.05, hrp.Velocity.Z)
        end

        -- 3. 周辺の透明パーツを「完全に無視」させる
        local parts = workspace:GetPartBoundsInRadius(hrp.Position, 12)
        for _, p in pairs(parts) do
            if p:IsA("BasePart") and (p.Transparency > 0 or p.Parent:FindFirstChild("Humanoid")) then
                p.CanCollide = false
            end
        end
    else
        -- OFFにした瞬間、物理判定を正常に戻す（埋まって動けなくなるのを防ぐ）
        -- ただし、壁の中にいるときにOFFにすると即死・即戻しされるので注意
    end
end)

-- サーバーからの「位置修正パケット」を一部無視する設定（可能なエグゼキューターのみ）
settings().Physics.AllowSleep = true
