-- Local Script
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local AdminEvent = ReplicatedStorage:WaitForChild("AdminEvent")
local frame = script.Parent:WaitForChild("Frame")

-- 視界妨害ボタン
frame.Button1.MouseButton1Click:Connect(function()
    AdminEvent:FireServer("BlindAll")
end)

-- グローブ取得ボタン
frame.Button2.MouseButton1Click:Connect(function()
    AdminEvent:FireServer("GiveGlove")
end)

-- キック用（簡易版：テキストボックスに名前を入れてボタンを押す形式）
frame.Button3.MouseButton1Click:Connect(function()
    local target = frame.TextBox.Text -- 名前入力欄を作っておく
    AdminEvent:FireServer("Kick", target)
end)
