local player = game.Players.LocalPlayer
local runService = game:GetService("RunService")

local spawnLocation = nil
local isTeleporting = false

-- UI
local screenGui = Instance.new("ScreenGui")
screenGui.Parent = player:WaitForChild("PlayerGui")
screenGui.ResetOnSpawn = false

local function createBtn(text, pos, color)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 45, 0, 45)
    btn.Position = pos
    btn.BackgroundColor3 = color
    btn.Text = text
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Font = Enum.Font.SourceSansBold
    btn.Parent = screenGui
    Instance.new("UICorner").Parent = btn
    return btn
end

local setBtn = createBtn("SET", UDim2.new(1, -115, 0, 25), Color3.fromRGB(0, 100, 200))
local getBtn = createBtn("GET", UDim2.new(1, -60, 0, 25), Color3.fromRGB(60, 60, 60))

-- [SET] 処理
setBtn.MouseButton1Click:Connect(function()
    local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if hrp then
        spawnLocation = hrp.CFrame
        setBtn.BackgroundColor3 = Color3.fromRGB(0, 255, 100)
        getBtn.BackgroundColor3 = Color3.fromRGB(255, 165, 0)
        task.wait(0.5)
        setBtn.BackgroundColor3 = Color3.fromRGB(0, 100, 200)
    end
end)

-- [GET] 処理：掴んでいるものすべてを道連れにするワープ
getBtn.MouseButton1Click:Connect(function()
    if isTeleporting or not spawnLocation then return end
    isTeleporting = true
    getBtn.BackgroundColor3 = Color3.fromRGB(255, 0, 0)

    local char = player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    
    if hrp then
        local enemyPos = hrp.CFrame
        
        -- 1. 納品場所の「少し上」に移動（地面との衝突死を防ぐ）
        local targetPos = spawnLocation * CFrame.new(0, 2, 0)
        
        -- 2. 【最重要】自分と「繋がっている」パーツをすべて強制移動させる
        -- これにより、掴んでいるキャラも一緒にワープさせます
        local function teleportAll(newCFrame)
            -- 自分の体を移動
            hrp.CFrame = newCFrame
            
            -- 自分に接続されている他人のパーツを探して強制同期
            for _, v in pairs(workspace:GetDescendants()) do
                if v:IsA("BasePart") and not v:IsDescendantOf(char) then
                    -- 自分の体の近くにあり、かつ拘束(Weld等)されている可能性が高いものをチェック
                    if (v.Position - hrp.Position).Magnitude < 10 then
                        -- パーツ自体ではなく、その親モデル（キャラ全体）を動かす
                        local model = v:FindFirstAncestorOfClass("Model")
                        if model and model:FindFirstChild("HumanoidRootPart") then
                             model.HumanoidRootPart.CFrame = newCFrame
                        end
                    end
                end
            end
        end

        -- 納品実行
        teleportAll(targetPos)
        task.wait(0.5) -- サーバーが「キャラが届いた」と判定するのを待つ
        
        -- 敵基地へ戻る
        teleportAll(enemyPos)
    end

    getBtn.BackgroundColor3 = Color3.fromRGB(255, 165, 0)
    isTeleporting = false
end)
