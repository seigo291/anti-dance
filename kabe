local player = game.Players.LocalPlayer
local runService = game:GetService("RunService")

local ghostActive = false
local ghostChar = nil

-- UI
local screenGui = Instance.new("ScreenGui")
screenGui.Parent = player:WaitForChild("PlayerGui")
screenGui.ResetOnSpawn = false

local function createBtn(text, pos, color)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 100, 0, 45)
    btn.Position = pos
    btn.BackgroundColor3 = color
    btn.Text = text
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Font = Enum.Font.SourceSansBold
    btn.Parent = screenGui
    Instance.new("UICorner").Parent = btn
    return btn
end

local ghostBtn = createBtn("GHOST MODE", UDim2.new(1, -110, 0, 25), Color3.fromRGB(40, 40, 40))

-- ゴーストモード：物理的な干渉をすべてバイパスする
ghostBtn.MouseButton1Click:Connect(function()
    ghostActive = not ghostActive
    ghostBtn.BackgroundColor3 = ghostActive and Color3.fromRGB(0, 255, 100) or Color3.fromRGB(40, 40, 40)
    
    local char = player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    if ghostActive then
        -- 【発動時】物理演算から切り離す
        -- キャラクターを空中にわずかに浮かせて「アンカー」する
        hrp.Anchored = true
        
        -- 移動用のループ（サーバーの座標チェックを騙す）
        task.spawn(function()
            while ghostActive do
                local moveDir = char.Humanoid.MoveDirection
                if moveDir.Magnitude > 0 then
                    -- アンカーされた状態で座標を少しずつずらす（サーバーには「歩いている」ように見えない）
                    hrp.CFrame = hrp.CFrame + (moveDir * 0.8) -- 速度調整
                end
                
                -- すべてのパーツの衝突判定を毎フレーム強制OFF
                for _, v in pairs(char:GetDescendants()) do
                    if v:IsA("BasePart") then v.CanCollide = false end
                end
                runService.Heartbeat:Wait()
            end
            hrp.Anchored = false -- 解除
        end)
    else
        hrp.Anchored = false
    end
end)

-- 攻撃（ノックバック）対策：速度を常にゼロに上書き
runService.Heartbeat:Connect(function()
    if ghostActive and player.Character then
        local hrp = player.Character:FindFirstChild("HumanoidRootPart")
        if hrp then
            hrp.Velocity = Vector3.new(0, 0, 0)
            hrp.RotVelocity = Vector3.new(0, 0, 0)
        end
    end
end)
