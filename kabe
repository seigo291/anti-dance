local player = game.Players.LocalPlayer
local runService = game:GetService("RunService")

local spawnLocation = nil
local isTeleporting = false

-- UI
local screenGui = Instance.new("ScreenGui")
screenGui.Parent = player:WaitForChild("PlayerGui")
screenGui.ResetOnSpawn = false

local function createBtn(text, pos, color)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 45, 0, 45)
    btn.Position = pos
    btn.BackgroundColor3 = color
    btn.Text = text
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Font = Enum.Font.SourceSansBold
    btn.Parent = screenGui
    Instance.new("UICorner").Parent = btn
    return btn
end

local setBtn = createBtn("SET", UDim2.new(1, -115, 0, 25), Color3.fromRGB(0, 100, 200))
local getBtn = createBtn("GET", UDim2.new(1, -60, 0, 25), Color3.fromRGB(60, 60, 60))

-- [SET] 処理
setBtn.MouseButton1Click:Connect(function()
    local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if hrp then
        spawnLocation = hrp.CFrame
        setBtn.BackgroundColor3 = Color3.fromRGB(0, 255, 100)
        getBtn.BackgroundColor3 = Color3.fromRGB(255, 165, 0)
        task.wait(0.5)
        setBtn.BackgroundColor3 = Color3.fromRGB(0, 100, 200)
    end
end)

-- [GET] 処理：物理エンジンを道連れにする
getBtn.MouseButton1Click:Connect(function()
    if isTeleporting or not spawnLocation then return end
    isTeleporting = true
    getBtn.BackgroundColor3 = Color3.fromRGB(255, 0, 0)

    local char = player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    
    if hrp then
        local enemyPos = hrp.CFrame
        
        -- 1. 周囲にある「掴んでいる可能性が高いパーツ」をすべてリストアップ
        local carryParts = {}
        for _, v in pairs(workspace:GetDescendants()) do
            if v:IsA("BasePart") and not v:IsDescendantOf(char) then
                if (v.Position - hrp.Position).Magnitude < 8 then
                    table.insert(carryParts, v)
                    -- サーバー側の「位置戻し」に抵抗するため一時的にアンカーを外す
                    v.Anchored = false 
                end
            end
        end

        -- 2. 自分と対象物を「同時」に座標上書き
        local function instantMove(targetCF)
            hrp.CFrame = targetCF
            for _, p in pairs(carryParts) do
                p.CFrame = targetCF
                p.Velocity = Vector3.new(0, 0, 0) -- 慣性で飛んでいくのを防ぐ
            end
        end

        -- 納品場所へ（判定のために0.3秒滞在）
        instantMove(spawnLocation)
        task.wait(0.3)
        
        -- 3. 【重要】納品ポイントで一度だけ「微動」させてTouchedを誘発
        instantMove(spawnLocation * CFrame.new(0, 0.2, 0))
        task.wait(0.1)
        
        -- 敵基地へ戻る
        instantMove(enemyPos)
    end

    getBtn.BackgroundColor3 = Color3.fromRGB(255, 165, 0)
    isTeleporting = false
end)
