local player = game.Players.LocalPlayer
local runService = game:GetService("RunService")

-- 【設定】Dexで調べた「窓のすぐ内側」の座標をここに入れる
-- とりあえず現在の位置から「前方に15スタッド」ワープする設定にしています
local teleportDistance = 15 

local screenGui = Instance.new("ScreenGui")
screenGui.Parent = player:WaitForChild("PlayerGui")
screenGui.ResetOnSpawn = false

local function createBtn(text, pos, color)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 120, 0, 50)
    btn.Position = pos
    btn.BackgroundColor3 = color
    btn.Text = text
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Font = Enum.Font.SourceSansBold
    btn.Parent = screenGui
    Instance.new("UICorner").Parent = btn
    return btn
end

local bypassBtn = createBtn("WINDOW BYPASS", UDim2.new(0.5, -60, 1, -100), Color3.fromRGB(255, 50, 50))

bypassBtn.MouseButton1Click:Connect(function()
    local char = player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    -- 1. 掴んでいるターゲットを特定
    local targetHRP = nil
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") and not v:IsDescendantOf(char) then
            if (v.Position - hrp.Position).Magnitude < 10 then
                local model = v:FindFirstAncestorOfClass("Model")
                if model and model:FindFirstChild("HumanoidRootPart") then
                    targetHRP = model.HumanoidRootPart
                    break
                end
            end
        end
    end

    -- 2. サーバーが「壁に当たった」と判定する前に、一気に座標を書き換える
    -- 自分の向きに合わせて、前方の「壁の向こう側」へ
    local targetPos = hrp.CFrame * CFrame.new(0, 0, -teleportDistance)
    
    -- 物理演算を一時停止して位置を確定させる
    hrp.Anchored = true
    hrp.CFrame = targetPos
    if targetHRP then
        targetHRP.Anchored = true
        targetHRP.CFrame = targetPos
    end
    
    -- サーバーが位置を認識するまでわずかに待機（0.1秒）
    task.wait(0.1)
    
    hrp.Anchored = false
    if targetHRP then targetHRP.Anchored = false end
    
    bypassBtn.Text = "BYPASSED!"
    task.wait(1)
    bypassBtn.Text = "WINDOW BYPASS"
end)
