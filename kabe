local player = game.Players.LocalPlayer
local runService = game:GetService("RunService")
local noclipEnabled = false

-- UI
local screenGui = Instance.new("ScreenGui")
screenGui.Parent = player:WaitForChild("PlayerGui")
screenGui.ResetOnSpawn = false
local toggleBtn = Instance.new("TextButton")
toggleBtn.Size = UDim2.new(0, 45, 0, 45)
toggleBtn.Position = UDim2.new(1, -65, 0, 25)
toggleBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
toggleBtn.Text = "OFF"
toggleBtn.Parent = screenGui
Instance.new("UICorner").Parent = toggleBtn

toggleBtn.MouseButton1Click:Connect(function()
    noclipEnabled = not noclipEnabled
    toggleBtn.Text = noclipEnabled and "ON" or "OFF"
    toggleBtn.BackgroundColor3 = noclipEnabled and Color3.fromRGB(0, 200, 100) or Color3.fromRGB(40, 40, 40)
end)

-- サーバー監視を飛び越えるロジック
runService.Stepped:Connect(function()
    if not noclipEnabled then return end
    
    local char = player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    local hum = char and char:FindFirstChild("Humanoid")
    if not hrp or not hum then return end

    -- 物理判定を完全に無効化
    for _, part in pairs(char:GetDescendants()) do
        if part:IsA("BasePart") then
            part.CanCollide = false
        end
    end

    -- 移動中のみ、座標を「飛び越え（Blink）」させる
    if hum.MoveDirection.Magnitude > 0 then
        -- 0.5スタッドずつ瞬間移動（サーバーが戻す速度より速く移動）
        hrp.CFrame = hrp.CFrame + (hum.MoveDirection * 0.6)
    end
    
    -- 落下防止：足元に透明な足場を仮定するか、Y軸の速度を固定
    hrp.Velocity = Vector3.new(0, 0, 0)
end)
