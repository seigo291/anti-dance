local player = game.Players.LocalPlayer
local tweenService = game:GetService("TweenService")

local spawnLocation = nil
local isTeleporting = false

-- UI
local screenGui = Instance.new("ScreenGui")
screenGui.Parent = player:WaitForChild("PlayerGui")
screenGui.ResetOnSpawn = false

local function createBtn(text, pos, color)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 45, 0, 45)
    btn.Position = pos
    btn.BackgroundColor3 = color
    btn.Text = text
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Font = Enum.Font.SourceSansBold
    btn.Parent = screenGui
    Instance.new("UICorner").Parent = btn
    return btn
end

local setBtn = createBtn("SET", UDim2.new(1, -115, 0, 25), Color3.fromRGB(0, 100, 200))
local getBtn = createBtn("GET", UDim2.new(1, -60, 0, 25), Color3.fromRGB(60, 60, 60))

-- 状態ロック関数（死亡と落下死を防止）
local function lockCharacter(state)
    local char = player.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if hum and hrp then
        hum:SetStateEnabled(Enum.HumanoidStateType.Dead, not state)
        hrp.Anchored = state -- 移動中以外は物理演算を止める
    end
end

-- 高精度・低検知テレポート
local function smoothMove(targetCFrame)
    local char = player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    -- 物理判定を消して「すり抜け」状態にする
    for _, v in pairs(char:GetDescendants()) do
        if v:IsA("BasePart") then v.CanCollide = false end
    end

    -- サーバーが「瞬間移動」と判定しないギリギリの速度 (0.25秒)
    local tween = tweenService:Create(hrp, TweenInfo.new(0.25, Enum.EasingStyle.Sine), {CFrame = targetCFrame})
    hrp.Anchored = false
    tween:Play()
    tween.Completed:Wait()
    hrp.Anchored = true
end

-- [SET] 処理
setBtn.MouseButton1Click:Connect(function()
    local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if hrp then
        spawnLocation = hrp.CFrame
        setBtn.BackgroundColor3 = Color3.fromRGB(0, 255, 100)
        getBtn.BackgroundColor3 = Color3.fromRGB(255, 165, 0)
        task.wait(0.5)
        setBtn.BackgroundColor3 = Color3.fromRGB(0, 100, 200)
    end
end)

-- [GET] 処理
getBtn.MouseButton1Click:Connect(function()
    if isTeleporting or not spawnLocation then return end
    isTeleporting = true
    getBtn.Text = "WAIT"
    getBtn.BackgroundColor3 = Color3.fromRGB(255, 0, 0)

    local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if hrp then
        local currentPos = hrp.CFrame
        
        -- 1. 死亡判定ロック
        lockCharacter(true)
        
        -- 2. 納品場所へ「滑らかに」移動
        smoothMove(spawnLocation)
        
        -- 3. 重要：納品判定を確定させるための「静止」時間 (0.4秒)
        -- これが短いと「一瞬すぎて触れていない」と判定されます
        task.wait(0.4)
        
        -- 4. 敵基地へ「滑らかに」戻る
        smoothMove(currentPos)
        
        -- 5. ロック解除
        lockCharacter(false)
    end

    getBtn.Text = "GET"
    getBtn.BackgroundColor3 = Color3.fromRGB(255, 165, 0)
    isTeleporting = false
end)
