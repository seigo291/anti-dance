local player = game.Players.LocalPlayer
local runService = game:GetService("RunService")
local noclipEnabled = false

-- UI作成
local screenGui = Instance.new("ScreenGui")
screenGui.Parent = player:WaitForChild("PlayerGui")
screenGui.ResetOnSpawn = false

local toggleBtn = Instance.new("TextButton")
toggleBtn.Size = UDim2.new(0, 50, 0, 50)
toggleBtn.Position = UDim2.new(1, -70, 0, 30) -- 右上
toggleBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
toggleBtn.Text = "PUSH" -- 押すだけなのでPUSHに変更
toggleBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
toggleBtn.Font = Enum.Font.SourceSansBold
toggleBtn.Parent = screenGui
Instance.new("UICorner").Parent = toggleBtn

-- 0.2秒だけONにする関数
toggleBtn.MouseButton1Click:Connect(function()
    if noclipEnabled then return end -- すでに実行中なら無視
    
    noclipEnabled = true
    toggleBtn.BackgroundColor3 = Color3.fromRGB(0, 255, 100)
    toggleBtn.Text = "GO!"
    
    -- 0.2秒待ってから自動でOFF
    task.wait(0.2)
    
    noclipEnabled = false
    toggleBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    toggleBtn.Text = "PUSH"
end)

-- 実行ロジック
runService.Stepped:Connect(function()
    if not noclipEnabled then return end
    
    local char = player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    local hum = char and char:FindFirstChild("Humanoid")
    if not hrp or not hum then return end

    -- 自身の衝突判定をオフ
    for _, part in pairs(char:GetDescendants()) do
        if part:IsA("BasePart") then
            part.CanCollide = false
        end
    end

    -- 0.2秒の間、スティックを倒している方向に高速移動（壁を突き抜ける）
    if hum.MoveDirection.Magnitude > 0 then
        -- 前回の0.8からさらに強化。一瞬で抜けるために距離を稼ぐ
        hrp.CFrame = hrp.CFrame + (hum.MoveDirection * 1.5)
    end
    
    -- 物理エンジンの介入を防止
    hrp.Velocity = Vector3.new(0, 0, 0)
end)
