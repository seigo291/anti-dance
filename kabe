local player = game.Players.LocalPlayer
local spawnLocation = nil
local isTeleporting = false

-- UI作成
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "FinalFixSystem"
screenGui.Parent = player:WaitForChild("PlayerGui")
screenGui.ResetOnSpawn = false

local function createBtn(text, pos, color)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 60, 0, 45)
    btn.Position = pos
    btn.BackgroundColor3 = color
    btn.Text = text
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Font = Enum.Font.SourceSansBold
    btn.Parent = screenGui
    Instance.new("UICorner").Parent = btn
    return btn
end

local setBtn = createBtn("SET", UDim2.new(1, -135, 0, 25), Color3.fromRGB(0, 100, 200))
local getBtn = createBtn("GET", UDim2.new(1, -70, 0, 25), Color3.fromRGB(60, 60, 60))

-- [SET] 処理
setBtn.MouseButton1Click:Connect(function()
    local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if hrp then
        spawnLocation = hrp.CFrame
        setBtn.Text = "OK"
        task.wait(1)
        setBtn.Text = "SET"
    end
end)

-- [GET] 処理：物理接触しているものだけを運ぶ
getBtn.MouseButton1Click:Connect(function()
    if isTeleporting or not spawnLocation then return end
    
    local char = player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    isTeleporting = true
    getBtn.BackgroundColor3 = Color3.fromRGB(255, 0, 0)

    -- 現在地を保存
    local enemyPos = hrp.CFrame

    -- 【超軽量ロジック】自分の足や手に「触れている」パーツを特定
    local targetParts = {}
    local touching = hrp:GetTouchingParts() -- RootPartに触れているものを直接取得
    
    for _, p in pairs(touching) do
        if not p:IsDescendantOf(char) then
            table.insert(targetParts, p)
        end
    end

    -- ワープ実行
    hrp.CFrame = spawnLocation
    for _, p in pairs(targetParts) do
        if p and p.Parent then p.CFrame = spawnLocation end
    end

    task.wait(0.6) -- 納品判定待ち

    -- 戻る
    hrp.CFrame = enemyPos
    
    isTeleporting = false
    getBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
end)
