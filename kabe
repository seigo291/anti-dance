local player = game.Players.LocalPlayer
local runService = game:GetService("RunService")
local noclipEnabled = false

-- UI
local screenGui = Instance.new("ScreenGui")
screenGui.Parent = player:WaitForChild("PlayerGui")
screenGui.ResetOnSpawn = false
local toggleBtn = Instance.new("TextButton")
toggleBtn.Size = UDim2.new(0, 50, 0, 50)
toggleBtn.Position = UDim2.new(1, -70, 0, 30)
toggleBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
toggleBtn.Text = "PUSH"
toggleBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
toggleBtn.Parent = screenGui
Instance.new("UICorner").Parent = toggleBtn

-- 0.2秒間の「超高速・高密度」壁抜け
toggleBtn.MouseButton1Click:Connect(function()
    if noclipEnabled then return end
    noclipEnabled = true
    toggleBtn.BackgroundColor3 = Color3.fromRGB(255, 200, 0) -- 実行中(オレンジ)
    
    local char = player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    local hum = char and char:FindFirstChild("Humanoid")
    
    if hrp and hum then
        -- 1. 衝突判定をオフ
        for _, v in pairs(char:GetDescendants()) do
            if v:IsA("BasePart") then v.CanCollide = false end
        end

        -- 2. 0.2秒間、超高速で座標を更新し続ける（サーバーの補正を上回る速度）
        local startTime = tick()
        while tick() - startTime < 0.2 do
            local moveDir = hum.MoveDirection
            if moveDir.Magnitude == 0 then moveDir = hrp.CFrame.LookVector end
            
            -- 座標を細かく更新（これが一番戻されにくい）
            hrp.CFrame = hrp.CFrame + (moveDir * 0.7)
            -- 物理的な押し戻しに対抗する速度を付与
            hrp.Velocity = moveDir * 100 
            
            runService.Heartbeat:Wait() -- サーバーとの同期タイミングで実行
        end
    end

    noclipEnabled = false
    toggleBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    toggleBtn.Text = "PUSH"
end)
