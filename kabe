local tool = script.Parent
local handle = tool:WaitForChild("Handle")

-- 設定
local catchRange = 10 -- 判定を広げるサイズ（大きくするほど当たりやすくなる）
local isCatching = false

-- 判定用の透明なパーツを作成（必中化のキモ）
local hitBox = Instance.new("Part")
hitBox.Name = "HitBox"
hitBox.Shape = Enum.PartType.Ball
hitBox.Size = Vector3.new(catchRange, catchRange, catchRange)
hitBox.Transparency = 1 -- 透明
hitBox.CanCollide = false
hitBox.Parent = handle

local weld = Instance.new("WeldConstraint")
weld.Part0 = handle
weld.Part1 = hitBox
weld.Parent = hitBox

hitBox.Touched:Connect(function(hit)
    if isCatching or not tool.Parent:FindFirstChild("Humanoid") then return end
    
    local myChar = tool.Parent
    local targetChar = hit.Parent
    local targetHum = targetChar:FindFirstChild("Humanoid")
    local targetRoot = targetChar:FindFirstChild("HumanoidRootPart")
    local myRoot = myChar:FindFirstChild("HumanoidRootPart")

    -- 相手が自分でない人間かチェック
    if targetHum and targetChar ~= myChar and targetRoot then
        isCatching = true
        
        -- 【重要】ラグ対策：まずサーバー側で強制的に位置を合わせる
        targetRoot.CFrame = myRoot.CFrame * CFrame.new(0, 0, -3) -- 自分の少し前にワープ
        
        -- 物理演算を無視して固定
        local catchWeld = Instance.new("WeldConstraint")
        catchWeld.Name = "CatchWeld"
        catchWeld.Part0 = myRoot
        catchWeld.Part1 = targetRoot
        catchWeld.Parent = targetRoot
        
        -- 相手を無力化
        targetHum.PlatformStand = true
        
        -- 演出：キャッチした瞬間に音や光を出すと分かりやすい
        local sound = Instance.new("Sound", handle)
        sound.SoundId = "rbxassetid://12222200" -- 好きなSEのID
        sound:Play()
    end
end)

-- ツールを離した時にキャッチ状態をリセットする場合（必要に応じて）
tool.Unequipped:Connect(function()
    isCatching = false
end)
